# ──────────────────────────────────────────────────────────────
#  TillWeDo Backend — Environment Variables
#  Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────

# ---- Server ----
NODE_ENV=development
PORT=5000
# Frontend origin (used for CORS). Vite dev server defaults to 5173.
CLIENT_URL=http://localhost:5173

# ---- Database (MongoDB Atlas) ----
# From Atlas: Database > Connect > Drivers. Include the db name before the "?".
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tillwedo?retryWrites=true&w=majority

# ---- Auth (JWT) ----
# Use a long random string, e.g. `openssl rand -hex 64`
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ---- Razorpay (payments) ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Set this in Razorpay Dashboard > Webhooks; used to verify webhook HMAC.
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Cloudinary (marriage proof / profile photo storage) ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Email ----
# Preferred: Resend (HTTP API, works on Railway/cloud hosts where SMTP ports are blocked).
# Get a key at https://resend.com — free tier is fine for dev/testing.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="TillWeDo <no-reply@tillwedo.app>"

# Fallback: Nodemailer over SMTP / Gmail (only used if RESEND_API_KEY is not set).
# NOTE: many cloud hosts (Railway included) block outbound SMTP ports 25/465/587 —
# this will only work locally unless your host explicitly allows SMTP egress.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@gmail.com
# For Gmail use an App Password (not your account password).
EMAIL_PASS=your_app_password

# ---- Business rules (configurable) ----
# Breakup cooling-off window in hours (blueprint §5.4 = 48).
BREAKUP_COOLING_HOURS=48
# Grace window (days) after a failed contribution (blueprint §5.3 = 3).
CONTRIBUTION_GRACE_DAYS=3
# What happens to a forfeited vault: "charity" or "platform" (blueprint §5.4).
FORFEITURE_MODE=platform
# Default annual interest rate (%) — also defaulted in the Vault schema.
DEFAULT_INTEREST_RATE=5.0

CRON_TIMEZONE=Asia/Kolkata
DISABLE_CRONS=false